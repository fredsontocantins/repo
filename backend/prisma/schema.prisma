generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ──────────────────────────────────────────────
model Organization {
  id                Int       @id @default(autoincrement())
  name              String
  slug              String    @unique
  description       String?
  website           String?
  logoUrl           String?
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  cnpj              String?
  portalAtivo       Boolean   @default(true)
  portalDescricao   String?
  portalCorPrimaria String    @default("#22c55e")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users        User[]
  volunteers   Volunteer[]
  campaigns    Campaign[]
  events       Event[]
  donations    Donation[]
  certificates Certificate[]
  members      Member[]
  payables     Payable[]
  receivables  Receivable[]
  interests    CampaignInterest[]

  @@index([slug])
}

// ─── Enums: Auth / Users ───────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  ADMIN
  COORDINATOR
  VOLUNTEER
}

enum MemberRole {
  DIRECTOR
  MANAGER
  COORDINATOR
  ANALYST
  INTERN
}

// ─── User ──────────────────────────────────────────────────────
model User {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  name           String
  passwordHash   String
  role           UserRole      @default(VOLUNTEER)
  avatarUrl      String?
  isActive       Boolean       @default(true)
  modules        Json?
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  volunteer      Volunteer?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([email])
  @@index([organizationId])
}

// ─── Member (equipe interna) ───────────────────────────────────
model Member {
  id             Int          @id @default(autoincrement())
  nome           String
  email          String
  cargo          String?
  role           MemberRole   @default(ANALYST)
  departamento   String?
  telefone       String?
  avatarUrl      String?
  bio            String?
  isActive       Boolean      @default(true)
  dataIngresso   DateTime     @default(now())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ─── Enums: Volunteer / Campaign / Donation / Event ───────────
enum VolunteerStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum DonationType {
  MONETARY
  FOOD
  CLOTHING
  MEDICINE
  EQUIPMENT
  SERVICE
  OTHER
}

enum DonationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum EventStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum CertificateType {
  PARTICIPATION
  HOURS
  ACHIEVEMENT
  RECOGNITION
}

// ─── Enums: Finance ────────────────────────────────────────────
enum PayableStatus {
  A_PAGAR
  PAGO
  VENCIDO
  CANCELADO
  ESTORNADO
}

enum PayableCategory {
  SALARIO
  ALUGUEL
  SERVICO
  MATERIAL
  TRANSPORTE
  ALIMENTACAO
  MARKETING
  JURIDICO
  CONTABILIDADE
  TECNOLOGIA
  OUTRO
}

enum ReceivableStatus {
  A_RECEBER
  RECEBIDO
  VENCIDO
  CANCELADO
  ESTORNADO
}

enum ReceivableCategory {
  DOACAO
  PATROCINIO
  SUBVENCAO
  PROJETO
  EVENTO
  SERVICO_PRESTADO
  REEMBOLSO
  OUTRO
}

// ─── Volunteer ─────────────────────────────────────────────────
model Volunteer {
  id                Int             @id @default(autoincrement())
  nome              String
  email             String?
  telefone          String?
  cpf               String?
  dataNascimento    DateTime?
  profissao         String?
  habilidades       String[]
  bio               String?
  avatarUrl         String?
  endereco          String?
  cidade            String?
  estado            String?
  status            VolunteerStatus @default(ACTIVE)
  pontos            Int             @default(0)
  horasContribuidas Float           @default(0)
  publicProfile     Boolean         @default(true)
  organizationId    Int
  organization      Organization    @relation(fields: [organizationId], references: [id])
  userId            Int?            @unique
  user              User?           @relation(fields: [userId], references: [id])
  donations         Donation[]
  eventRegistrations EventRegistration[]
  badges            VolunteerBadge[]
  campaignVolunteers CampaignVolunteer[]
  certificates      Certificate[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([pontos])
}

// ─── Campaign ──────────────────────────────────────────────────
model Campaign {
  id               Int            @id @default(autoincrement())
  nome             String
  descricao        String?
  objetivo         String?
  metaArrecadacao  Float?
  arrecadado       Float          @default(0)
  metaVoluntarios  Int?
  voluntariosAtivos Int           @default(0)
  status           CampaignStatus @default(DRAFT)
  dataInicio       DateTime?
  dataFim          DateTime?
  imagemUrl        String?
  publicavel       Boolean        @default(true)
  destaque         Boolean        @default(false)
  organizationId   Int
  organization     Organization   @relation(fields: [organizationId], references: [id])
  donations        Donation[]
  volunteers       CampaignVolunteer[]
  events           Event[]
  certificates     Certificate[]
  receivables      Receivable[]
  interests        CampaignInterest[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([publicavel])
}

model CampaignVolunteer {
  id               Int       @id @default(autoincrement())
  campaignId       Int
  campaign         Campaign  @relation(fields: [campaignId], references: [id])
  volunteerId      Int
  volunteer        Volunteer @relation(fields: [volunteerId], references: [id])
  joinedAt         DateTime  @default(now())
  horasTrabalhadas Float     @default(0)

  @@unique([campaignId, volunteerId])
  @@index([campaignId])
  @@index([volunteerId])
}

// ─── Donation ──────────────────────────────────────────────────
model Donation {
  id             Int            @id @default(autoincrement())
  tipo           DonationType   @default(MONETARY)
  valor          Float?
  descricao      String?
  status         DonationStatus @default(CONFIRMED)
  doadorNome     String?
  doadorEmail    String?
  doadorTelefone String?
  mensagem       String?
  recibo         String?
  campaignId     Int?
  campaign       Campaign?      @relation(fields: [campaignId], references: [id])
  volunteerId    Int?
  volunteer      Volunteer?     @relation(fields: [volunteerId], references: [id])
  organizationId Int
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([campaignId])
  @@index([tipo])
  @@index([status])
}

enum CampaignInterestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CampaignInterest {
  id             Int                    @id @default(autoincrement())
  campaignId     Int
  campaign       Campaign               @relation(fields: [campaignId], references: [id])
  organizationId Int
  organization   Organization           @relation(fields: [organizationId], references: [id])
  nome           String
  email          String
  telefone       String?
  profissao      String?
  mensagem       String?
  status         CampaignInterestStatus @default(PENDING)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([campaignId])
  @@index([organizationId])
}

// ─── Event ─────────────────────────────────────────────────────
model Event {
  id             Int               @id @default(autoincrement())
  nome           String
  descricao      String?
  local          String?
  dataInicio     DateTime
  dataFim        DateTime?
  capacidade     Int?
  imagemUrl      String?
  status         EventStatus       @default(SCHEDULED)
  publicavel     Boolean           @default(true)
  campaignId     Int?
  campaign       Campaign?         @relation(fields: [campaignId], references: [id])
  organizationId Int
  organization   Organization      @relation(fields: [organizationId], references: [id])
  registrations  EventRegistration[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([dataInicio])
  @@index([publicavel])
}

model EventRegistration {
  id          Int       @id @default(autoincrement())
  eventId     Int
  event       Event     @relation(fields: [eventId], references: [id])
  volunteerId Int
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  checkedIn   Boolean   @default(false)
  checkinAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([eventId, volunteerId])
  @@index([eventId])
  @@index([volunteerId])
}

// ─── Gamification ──────────────────────────────────────────────
model Badge {
  id        Int              @id @default(autoincrement())
  nome      String
  descricao String?
  icone     String
  cor       String           @default("#6366f1")
  criterio  String?
  pontosReq Int              @default(0)
  horasReq  Float            @default(0)
  volunteers VolunteerBadge[]
  createdAt DateTime         @default(now())
}

model VolunteerBadge {
  id          Int       @id @default(autoincrement())
  volunteerId Int
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  badgeId     Int
  badge       Badge     @relation(fields: [badgeId], references: [id])
  earnedAt    DateTime  @default(now())

  @@unique([volunteerId, badgeId])
}

// ─── Certificate ───────────────────────────────────────────────
model Certificate {
  id                Int             @id @default(autoincrement())
  codigo            String          @unique
  tipo              CertificateType @default(PARTICIPATION)
  titulo            String
  descricao         String?
  horasCertificadas Float?
  dataAtividade     DateTime?
  dataEmissao       DateTime        @default(now())
  dataValidade      DateTime?
  volunteerId       Int
  volunteer         Volunteer       @relation(fields: [volunteerId], references: [id])
  campaignId        Int?
  campaign          Campaign?       @relation(fields: [campaignId], references: [id])
  organizationId    Int
  organization      Organization    @relation(fields: [organizationId], references: [id])
  emitidoPor        String?
  assinante         String?
  cargoAssinante    String?
  revogado          Boolean         @default(false)
  motivoRevogacao   String?
  createdAt         DateTime        @default(now())

  @@index([codigo])
  @@index([volunteerId])
  @@index([organizationId])
}

// ─── Report ────────────────────────────────────────────────────
model Report {
  id             Int      @id @default(autoincrement())
  nome           String
  tipo           String
  filtros        Json?
  dados          Json?
  organizationId Int
  geradoPor      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

// ─── Finance: Payable (Contas a Pagar) ────────────────────────
model Payable {
  id                 Int             @id @default(autoincrement())
  descricao          String
  categoria          PayableCategory @default(OUTRO)
  valor              Float
  vencimento         DateTime
  competencia        DateTime?
  status             PayableStatus   @default(A_PAGAR)
  fornecedor         String?
  cnpjFornecedor     String?
  notaFiscal         String?
  observacao         String?
  dataPagamento      DateTime?
  valorPago          Float?
  formaPagamento     String?
  comprovante        String?
  dataEstorno        DateTime?
  motivoEstorno      String?
  motivoCancelamento String?
  organizationId     Int
  organization       Organization    @relation(fields: [organizationId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([vencimento])
  @@index([categoria])
}

// ─── Finance: Receivable (Contas a Receber) ───────────────────
model Receivable {
  id                 Int                @id @default(autoincrement())
  descricao          String
  categoria          ReceivableCategory @default(DOACAO)
  valor              Float
  vencimento         DateTime
  competencia        DateTime?
  status             ReceivableStatus   @default(A_RECEBER)
  pagador            String?
  emailPagador       String?
  documentoPagador   String?
  notaFiscal         String?
  observacao         String?
  dataRecebimento    DateTime?
  valorRecebido      Float?
  formaRecebimento   String?
  comprovante        String?
  dataEstorno        DateTime?
  motivoEstorno      String?
  motivoCancelamento String?
  campaignId         Int?
  campaign           Campaign?          @relation(fields: [campaignId], references: [id])
  organizationId     Int
  organization       Organization       @relation(fields: [organizationId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([vencimento])
  @@index([categoria])
}
